generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email     String @id
  name      String
  role      String // ADMIN, FINANCE, ENTRY, VIEWER
  password  String // Hashed
  status    String @default("PENDING") // PENDING, ACTIVE, REJECTED
}

model Transaction {
  id            String   @id @default(cuid()) // DonationID
  date          DateTime @default(now())
  type          String   // DONATION, EXPENSE
  name          String   // Donor Name or Expense Item
  amount        Float
  paymentMethod String?  // CASH, BANK, MOBILE (Nullable for Expense)
  notes         String?
  enteredBy     String   // User Email
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
